# Joblytics AI environment variables
# Copy this file to .env.local for local development.
# In Vercel, add these values under Project Settings > Environment Variables.

# Client-side Supabase configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side Supabase configuration for /api functions
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic / Claude API configuration
ANTHROPIC_API_KEY=
# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_ANALYZE_MODEL=claude-sonnet-4-20250514,claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022
ANTHROPIC_COVER_LETTER_MODEL=claude-sonnet-4-20250514

# Admin access
# Comma-separated list, for example: admin@example.com,owner@example.com
ADMIN_EMAILS=

# Stripe billing - leave empty until billing is ready
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_JOB_SEARCH_PASS=
STRIPE_PRICE_PRO_MONTHLY=
PUBLIC_APP_URL=https://joblytics-ai.com
