# Keep Vercel Hobby deployments under the 12 Serverless Functions limit.
# The app currently needs only these production API routes:
# - /api/analyze
# - /api/profile-optimize
# - /api/profile-import
# - /api/cover-letter
# - /api/contact
# - /api/support-reply
# - /api/system-check

api/**
!api/analyze.js
!api/profile-optimize.js
!api/profile-import.js
!api/cover-letter.js
!api/contact.js
!api/support-reply.js
!api/system-check.js