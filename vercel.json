{
  "redirects": [
    {
      "source": "/api/mail-sync-callback",
      "destination": "/api/google-sync-callback",
      "permanent": false
    },
    {
      "source": "/api/sync-callback",
      "destination": "/api/google-sync-callback",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/sync-settings", "destination": "/api/mail-sync-start?_action=sync_settings" },
    { "source": "/api/auth/linkedin/me", "destination": "/api/linkedin-optimize?_action=auth_me" },
    { "source": "/api/auth/linkedin/logout", "destination": "/api/linkedin-optimize?_action=auth_logout" },
    { "source": "/api/auth/linkedin/start", "destination": "/api/linkedin-optimize?_action=auth_start" },
    { "source": "/api/auth/linkedin/callback", "destination": "/api/linkedin-optimize?_action=auth_callback" },
    { "source": "/api/linkedin-dma/start", "destination": "/api/linkedin-optimize?_action=dma_start" },
    { "source": "/api/linkedin-dma/callback", "destination": "/api/linkedin-optimize?_action=dma_callback" },
    { "source": "/api/linkedin-dma/import", "destination": "/api/linkedin-optimize?_action=dma_import" },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(self), fullscreen=(self)"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://accounts.google.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://api.stripe.com https://checkout.stripe.com https://accounts.google.com https://oauth2.googleapis.com https://www.googleapis.com https://graph.microsoft.com https://login.microsoftonline.com; frame-src 'self' https://js.stripe.com https://checkout.stripe.com https://accounts.google.com https://login.microsoftonline.com; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  }
}
